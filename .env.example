APP_NAME="USM PANTAS"

# CHED-style library holdings Excel report
# REPORT_HEI_NAME="GOVERNOR GENEROSO COLLEGE OF ARTS SCIENCES AND TECHNOLOGY"
# REPORT_PREPARED_BY_NAME="AMORMIO Z. REDONDA, RL"
# REPORT_APPROVED_BY_NAME="JANDY T. BONGCAYAT, LPT, FRIEDr, CHRA"
# REPORT_RECENT_YEARS=5
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
# Create this database before running migrations
DB_DATABASE=demo_2
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Production performance (recommended):
# SESSION_DRIVER=redis
# CACHE_STORE=redis

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
# Legacy alias for MAIL_SCHEME=smtps when using port 465
# MAIL_ENCRYPTION=ssl
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Hostinger (hPanel → Emails → Configuration → SMTP)
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.hostinger.com
# MAIL_PORT=465
# MAIL_SCHEME=smtps
# MAIL_USERNAME=support@pantas.org
# MAIL_PASSWORD=your-email-account-password
# MAIL_FROM_ADDRESS=support@pantas.org
# MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Per-school branding stylesheet (path under /public)
# Example per subdomain:
# BRANDING_CSS=branding/usm.css
BRANDING_CSS=branding/branding.css

# Local Flask sms_server.py (GSM modem). Must match API_KEY in sms_server.py.
SMS_MODEM_URL=http://127.0.0.1:5000/send-sms
# Change in production; must match sms_server.py if used
SMS_MODEM_API_KEY=your-secret-api-key

# Optional: Google Books API key for higher ISBN lookup quota (copy cataloging).
# Create at https://console.cloud.google.com/apis/library/books.googleapis.com
GOOGLE_BOOKS_API_KEY=
